# Database (Railway PostgreSQL)
# Public proxy URL (for local dev / migrations from your machine):
#   postgresql://postgres:[PASSWORD]@[HOST].proxy.rlwy.net:[PORT]/railway
# Internal URL (used by the backend service running on Railway):
#   postgresql://postgres:[PASSWORD]@postgres.railway.internal:5432/railway
# Append ?connection_limit=5&pool_timeout=20 so the single shared Prisma client
# stays well under the Postgres max_connections on small Railway plans.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST].proxy.rlwy.net:[PORT]/railway?connection_limit=5&pool_timeout=20"

# JWT
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_EXPIRES_IN="7d"

# Razorpay
RAZORPAY_KEY_ID="rzp_test_xxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"
# Webhook secret set in the Razorpay dashboard (required in production for
# payment.captured / order.paid signature verification + crash recovery)
RAZORPAY_WEBHOOK_SECRET="your-razorpay-webhook-secret"

# Cloudinary (image storage)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Email (Gmail) — leave blank to use mock (console.log) mode
GMAIL_USER=""
GMAIL_PASS=""

# App
PORT=5000
FRONTEND_URL="http://localhost:5173"
NODE_ENV="development"
